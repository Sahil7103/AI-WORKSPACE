# Database Configuration
DATABASE_URL=sqlite:///./ai_workplace_copilot.db
SQLALCHEMY_DB_URL=

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=False

# OpenAI Configuration
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4-turbo-preview
EMBEDDING_MODEL=text-embedding-3-small

# External LLM Configuration
LLM_API_URL=https://sk1354-llama3-career-api.hf.space/chat
LLM_API_TOKEN=
LLM_MODEL_LABEL=sk1354/llama3-career-api
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=1000

# Vector Database Configuration
USE_FAISS=True
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX_NAME=ai-copilot

# Slack Integration (Optional)
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_SIGNING_SECRET=your-signing-secret

# Gmail Integration (Optional)
GOOGLE_CREDENTIALS_JSON={}

# CORS Allowed Origins
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# Application Settings
APP_NAME=AI Workplace Copilot
APP_VERSION=1.0.0
ENVIRONMENT=development
PROCESS_DOCUMENTS_ON_UPLOAD=False
